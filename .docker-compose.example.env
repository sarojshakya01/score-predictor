# ─────────────────────────────────────────────────────────────────────────────
# Root .env  –  copy this file to .env and fill in real values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────
# Use host.docker.internal so the container can reach MySQL on the host machine.
# On macOS/Windows Docker Desktop exposes this automatically.
# On Linux it is wired up via extra_hosts: host.docker.internal:host-gateway
DATABASE_URL=mysql+aiomysql://wc_user:wc_pass@host.docker.internal:3306/worldcup2026

JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080
EMAIL_VERIFICATION_EXPIRE_MINUTES=10
PASSWORD_RESET_EXPIRE_MINUTES=3
TIMEZONE="Asia/Kathmandu"
LIVE_MATH_UPDATE_INTERVAL_MIN=1
MATCH_LOCK_CHECK_INTERVAL_MIN=5
REMINDER_CHECK_INTERVAL_MIN=30
MATCH_DAY_UPDATE_INTERVAL_HR=4
TODAYS_MATCH_REMINDER_TIME_HR=10
ADMIN_EMAIL=admin@email.com
EMAIL_FROM=your@email.com
EMAIL_PASS=your_app_password
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
SITE_URL=http://localhost:8026
API_BASE_PATH=/api/v1
CORS_ORIGINS=http://localhost:8026
OPENAI_ENDPOINT=endpoint
OPENAI_DEPLOYMENT_NAME=deployment_name
OPENAI_KEY=api_key

# ── Frontend (build-time) ─────────────────────────────────────────────────────
# This is baked into the Next.js bundle at build time.
NEXT_DEFAULT_TIMEZONE=Asia/Kathmandu
NEXT_PUBLIC_API_BASE_URL=http://localhost:8025/api/v1
